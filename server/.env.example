# ShiftSync Server Environment Variables
# Copy this file to .env and fill in your values.

# ─── App URLs ────────────────────────────────────────────────────────────────
# URL where this server is running (used for OAuth callback URLs)
SERVER_URL=http://localhost:3001

# URL where the React frontend is running (used for CORS + OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Server port (default: 3001)
PORT=3001

# ─── Security ────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Change this to a long random string in production!
JWT_SECRET=change-me-to-a-long-random-string

# ─── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite database file (default: server/shiftsync.db)
# DB_PATH=./shiftsync.db

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to add: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft OAuth ─────────────────────────────────────────────────────────
# Register an app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Redirect URI to add: http://localhost:3001/api/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Optional: restrict to a specific tenant. Leave blank for multi-tenant ('common').
MICROSOFT_TENANT_ID=
