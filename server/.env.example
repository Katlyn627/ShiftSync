# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Obtain credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Full URL to the OAuth callback handled by the server.
# • Leave unset (or omit) to use a relative path that is resolved at runtime
#   from the incoming request — this works for any host/port without extra config.
# • For local development the default resolves to:
#     http://localhost:3001/api/auth/google/callback
#   Register that exact URL in Google Cloud Console → Authorised redirect URIs.
# • For production set this to your deployed server URL, e.g.:
#     GOOGLE_CALLBACK_URL=https://myapp.example.com/api/auth/google/callback
#   and register that URL in Google Cloud Console as well.
# Using the wrong port (3000 vs 3001) or a mismatched production URL is the
# most common cause of Error 400: redirect_uri_mismatch.
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── Session (used by Google OAuth flow) ───────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
SESSION_SECRET=replace-with-a-strong-random-session-secret

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017/shiftsync
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/shiftsync?retryWrites=true&w=majority

# ── Client URL (used for post-OAuth redirect) ─────────────────────────────────
CLIENT_URL=http://localhost:3000
