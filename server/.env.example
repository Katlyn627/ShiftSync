# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Obtain credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Full URL to the OAuth callback handled by the server.
# • Leave unset (or omit) to use a relative path that is resolved at runtime
#   from the incoming request — this works for any host/port without extra config.
# • For local development the default resolves to:
#     http://localhost:3001/api/auth/google/callback
#   Register that exact URL in Google Cloud Console → Authorised redirect URIs.
# • For production set this to your deployed server URL, e.g.:
#     GOOGLE_CALLBACK_URL=https://myapp.example.com/api/auth/google/callback
#   and register that URL in Google Cloud Console as well.
# Using the wrong port (3000 vs 3001) or a mismatched production URL is the
# most common cause of Error 400: redirect_uri_mismatch.
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── Session (used by Google OAuth flow) ───────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
SESSION_SECRET=replace-with-a-strong-random-session-secret

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection URI — copy one of the lines below, uncomment it, and fill
# in your credentials.  The server will retry 5 times (5 s apart) on startup.
#
# ⚡ Zero-config default (no MONGODB_URI needed):
#   If MONGODB_URI is not set, the server automatically starts an in-memory
#   MongoDB instance via mongodb-memory-server.  The app works immediately with
#   no Atlas account or local MongoDB required.
#   ⚠  Data is lost on every restart — set one of the URIs below to persist data.
#
# MongoDB Atlas (cloud, SRV):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/shiftsync?retryWrites=true&w=majority
#
# MongoDB Atlas (cloud, standard non-SRV — use when SRV DNS is blocked):
# MONGODB_URI=mongodb://<user>:<pass>@<shard0>:27017,<shard1>:27017,<shard2>:27017/shiftsync?ssl=true&replicaSet=atlas-<cluster-id>-shard-0&authSource=admin
#
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/shiftsync

# ── Client URL (used for post-OAuth redirect) ─────────────────────────────────
CLIENT_URL=http://localhost:3000
