# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Obtain credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Full URL to the OAuth callback handled by the server
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── Session (used by Google OAuth flow) ───────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
SESSION_SECRET=replace-with-a-strong-random-session-secret

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (default: server/shiftsync.db)
DB_PATH=./shiftsync.db

# MongoDB connection URI (optional — for future migration from SQLite)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/shiftsync?retryWrites=true&w=majority

# ── Client URL (used for post-OAuth redirect) ─────────────────────────────────
CLIENT_URL=http://localhost:5173
