# ── Mobile (Capacitor) build environment ───────────────────────────────────
#
# Copy this file to .env.mobile before building the native app:
#
#   cp .env.mobile.example .env.mobile
#
# Then build:
#   npm run build:mobile          # builds web assets with this config
#   npx cap sync                  # copies assets + updates native plugins
#   npx cap open android          # opens Android Studio
#   npx cap open ios              # opens Xcode
#
# ── Required ───────────────────────────────────────────────────────────────

# Base URL of your deployed ShiftSync server (no trailing slash).
# All /api/... requests from the native app will be sent here.
VITE_API_BASE_URL=https://your-shiftsync-server.onrender.com
